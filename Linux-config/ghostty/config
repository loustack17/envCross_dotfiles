theme = Eldritch-Dark

font-family = SFMono Nerd Font
font-size = 12
font-feature = -liga
font-feature = -calt

cursor-style = bar
cursor-style-blink = false
adjust-cell-height = 2

scrollback-limit = 25000000
mouse-scroll-multiplier = 2
focus-follows-mouse = true

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-decoration = false
window-save-state = always
background-opacity = 0.985
window-vsync = true

gtk-tabs-location = top
gtk-wide-tabs = false
gtk-titlebar = false
gtk-custom-css = style.css

keybind = ctrl+shift+k=scroll_page_up
keybind = ctrl+shift+j=scroll_page_down

keybind = ctrl+shift+enter=new_window
keybind = F5=new_split:right
keybind = F6=new_split:down
keybind = F7=equalize_splits

keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+q=quit

keybind = ctrl+shift+]=goto_split:next
keybind = ctrl+shift+[=goto_split:previous
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right

keybind = ctrl+left=resize_split:left,10
keybind = ctrl+right=resize_split:right,10
keybind = ctrl+up=resize_split:up,10
keybind = ctrl+down=resize_split:down,10
keybind = ctrl+home=equalize_splits

keybind = ctrl+shift+z=toggle_split_zoom

keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+right=next_tab
keybind = ctrl+shift+left=previous_tab
