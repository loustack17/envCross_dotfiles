{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "center",
  "positionY": "top",
  "layer": "overlay",
  "control-center-positionX": "center",
  "control-center-positionY": "top",
  "control-center-margin-top": 10,
  "control-center-width": 560,
  "control-center-height": 640,
  "notification-window-width": 360,
  "notification-window-height": 104,
  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "fit-to-screen": false,
  "relative-timestamps": true,
  "image-visibility": "when-available",
  "hide-on-clear": false,
  "hide-on-action": true,
  "notification-visibility": {
    "mute-inhibited": false
  },
  "widgets": [
    "dnd",
    "title",
    "notifications"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    }
  }
}
