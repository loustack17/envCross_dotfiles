.shell powershell
.pause lwin + escape

lwin + ctrl + shift + o : komorebic replace-configuration "$env:USERPROFILE\komorebi.json"
lwin + shift + escape : komorebic toggle-shortcuts

lwin + ctrl + return : wt
lwin + ctrl + q : komorebic close
lwin + ctrl + m : komorebic minimize

lwin + ctrl + h : komorebic focus left
lwin + ctrl + j : komorebic focus down
lwin + ctrl + k : komorebic focus up
lwin + ctrl + l : komorebic focus right

lwin + ctrl + shift + h : komorebic move left
lwin + ctrl + shift + j : komorebic move down
lwin + ctrl + shift + k : komorebic move up
lwin + ctrl + shift + l : komorebic move right

lwin + shift + h : komorebic cycle-monitor previous
lwin + shift + l : komorebic cycle-monitor next
lwin + ctrl + alt + h : komorebic cycle-move-to-monitor previous
lwin + ctrl + alt + l : komorebic cycle-move-to-monitor next

lwin + ctrl + 1 : komorebic focus-workspace 0
lwin + ctrl + 2 : komorebic focus-workspace 1
lwin + ctrl + 3 : komorebic focus-workspace 2
lwin + ctrl + 4 : komorebic focus-workspace 3
lwin + ctrl + 5 : komorebic focus-workspace 4
lwin + ctrl + 6 : komorebic focus-workspace 5
lwin + ctrl + 7 : komorebic focus-workspace 6
lwin + ctrl + 8 : komorebic focus-workspace 7
lwin + ctrl + 9 : komorebic focus-workspace 8
lwin + ctrl + tab : komorebic focus-last-workspace

lwin + ctrl + shift + 1 : komorebic move-to-workspace 0
lwin + ctrl + shift + 2 : komorebic move-to-workspace 1
lwin + ctrl + shift + 3 : komorebic move-to-workspace 2
lwin + ctrl + shift + 4 : komorebic move-to-workspace 3
lwin + ctrl + shift + 5 : komorebic move-to-workspace 4
lwin + ctrl + shift + 6 : komorebic move-to-workspace 5
lwin + ctrl + shift + 7 : komorebic move-to-workspace 6
lwin + ctrl + shift + 8 : komorebic move-to-workspace 7
lwin + ctrl + shift + 9 : komorebic move-to-workspace 8

lwin + ctrl + oem_minus : komorebic resize-axis horizontal decrease
lwin + ctrl + oem_plus : komorebic resize-axis horizontal increase
lwin + ctrl + shift + oem_minus : komorebic resize-axis vertical decrease
lwin + ctrl + shift + oem_plus : komorebic resize-axis vertical increase

lwin + ctrl + t : komorebic toggle-float
lwin + ctrl + f : komorebic toggle-monocle
lwin + ctrl + w : komorebic stack-all
lwin + ctrl + u : komorebic cycle-stack previous
lwin + ctrl + i : komorebic cycle-stack next
lwin + ctrl + x : komorebic unstack
lwin + ctrl + shift + r : komorebic retile
lwin + ctrl + p : komorebic toggle-pause
