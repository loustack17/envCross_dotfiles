{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "apify-actor-development@apify-agent-skills": false,
    "apify-generate-output-schema@apify-agent-skills": false,
    "apify-ultimate-scraper@apify-agent-skills": false,
    "caveman@caveman": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": true,
    "common-lsp@lou-local-ai": true,
    "csharp-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "PROXY_MANAGED",
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:15721",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "deepseek-v4-flash",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "glm-5.1",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "deepseek-v4-pro",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "apify-agent-skills": {
      "autoUpdate": true,
      "source": {
        "source": "git",
        "url": "https://github.com/apify/agent-skills.git"
      }
    },
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "lou-local-ai": {
      "source": {
        "path": "~/Documents/WorkFlow/envCross_dotfiles/ai-assistants/.claude/marketplace",
        "source": "directory"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "repo": "obra/superpowers-marketplace",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "code-review-graph update --skip-flows",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/enforce-shell-policy.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "code-review-graph status",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "node \"/home/lou/.claude/hooks/caveman-activate.js\"",
            "statusMessage": "Loading caveman mode...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "node \"/home/lou/.claude/hooks/caveman-mode-tracker.js\"",
            "statusMessage": "Tracking caveman mode...",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "model": "opus",
  "permissions": {
    "allow": [
      "Fish",
      "Fish(pnpm *)",
      "Fish(rg *)",
      "Fish(bun *)",
      "Fish(bunx *)",
      "Fish(uv *)"
    ]
  },
  "statusLine": {
    "command": "~/.claude/statusline-command.sh",
    "padding": 1,
    "type": "command"
  },
  "theme": "dark-daltonized"
}