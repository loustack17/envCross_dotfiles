{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "edit": "ask",
    "write": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "rg *": "allow",
      "eza *": "allow",
      "bat *": "allow",
      "pnpm *": "ask",
      "bun *": "ask",
      "uv *": "ask",
      "git status*": "allow",
      "git diff*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "instructions": [
    "../AGENTS.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "cc-safety-net",
    "@slkiser/opencode-quota",
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "code-review-graph": {
      "type": "local",
      "command": [
        "uvx",
        "code-review-graph",
        "serve"
      ],
      "enabled": true
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "direnv",
        "exec",
        "/home/lou/Documents/WorkFlow/envCross_dotfiles/ai-assistants",
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "bash": {
      "command": [
        "bash-language-server",
        "start"
      ],
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".ksh",
        ".bashrc",
        ".zshrc"
      ]
    },
    "gopls": {
      "command": [
        "gopls"
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ]
    },
    "terraform": {
      "disabled": true
    },
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ]
    },
    "yaml-ls": {
      "command": [
        "yaml-language-server",
        "--stdio"
      ]
    },
    "json-ls": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc",
        ".code-workspace"
      ]
    },
    "fish-lsp": {
      "command": [
        "fish-lsp",
        "start"
      ],
      "extensions": [
        ".fish"
      ]
    },
    "tofu-ls": {
      "command": [
        "tofu-ls",
        "serve"
      ],
      "extensions": [
        ".tf",
        ".tfvars",
        ".tf.json",
        ".tofu",
        ".tofu.json"
      ]
    }
  }
}
