{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "*": "deny",
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "external_directory": "ask"
      },
      "tools": {
        "*": false,
        "apply_patch": true,
        "bash": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "read": true,
        "write": true
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "orchestrator": {
      "permission": {
        "*": "ask",
        "bash": "ask",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "read": "allow"
      },
      "tools": {
        "*": false,
        "apply_patch": true,
        "bash": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "read": true,
        "write": true
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "instructions": [
    "AGENTS.md"
  ],
  "lsp": {
    "bash": {
      "command": [
        "bash-language-server",
        "start"
      ],
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".ksh",
        ".bashrc",
        ".zshrc"
      ]
    },
    "fish-lsp": {
      "command": [
        "fish-lsp",
        "start"
      ],
      "extensions": [
        ".fish"
      ]
    },
    "gopls": {
      "command": [
        "gopls"
      ]
    },
    "json-ls": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc",
        ".code-workspace"
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ]
    },
    "terraform": {
      "disabled": true
    },
    "tofu-ls": {
      "command": [
        "tofu-ls",
        "serve"
      ],
      "extensions": [
        ".tf",
        ".tfvars",
        ".tf.json",
        ".tofu",
        ".tofu.json"
      ]
    },
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ]
    },
    "yaml-ls": {
      "command": [
        "yaml-language-server",
        "--stdio"
      ]
    }
  },
  "mcp": {
    "code-review-graph": {
      "command": [
        "uvx",
        "code-review-graph",
        "serve"
      ],
      "enabled": true,
      "type": "local"
    },
    "content-i18n": {
      "command": [
        "/home/lou/.local/bin/content-i18n",
        "mcp",
        "--config",
        "/home/lou/Documents/LouStackBase/content-i18n.yaml"
      ],
      "enabled": true,
      "type": "local"
    },
    "firecrawl": {
      "command": [
        "/home/lou/Documents/WorkFlow/envCross_dotfiles/scripts/mcp/run-firecrawl.sh"
      ],
      "enabled": true,
      "type": "local"
    },
    "markitdown": {
      "command": [
        "markitdown-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "mem0": {
      "command": [
        "/home/lou/Documents/WorkFlow/envCross_dotfiles/scripts/mcp/run-mem0.sh"
      ],
      "enabled": true,
      "type": "local"
    },
    "tavily": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/"
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "bat *": "allow",
      "bun *": "ask",
      "eza *": "allow",
      "git diff*": "allow",
      "git status*": "allow",
      "pnpm *": "ask",
      "rg *": "allow",
      "uv *": "ask"
    },
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "write": "ask"
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@latest",
    "cc-safety-net",
    "@slkiser/opencode-quota",
    "oh-my-opencode-slim"
  ]
}
