{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Fish",
      "Fish(pnpm *)",
      "Fish(rg *)",
      "Fish(bun *)",
      "Fish(bunx *)",
      "Fish(uv *)"
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: when showing commands to the user, provide Fish syntax instead of Bash or Zsh. Use eza instead of ls. Use pnpm or bun instead of npm. Use rg instead of grep. Run /simplify before any git commit. If /simplify finds issues, fix them, show the user what changed, and wait for approval before committing.'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Fish",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/enforce-shell-policy.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 1
  }
}
